{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  // Permissions - require approval for specific operations
  "permission": {
    // Global wildcard - applies to all tools not explicitly configured
    "*": "allow",
    "edit": {
      "*": "ask"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      // Always deny
      "git push*": "deny",
      "rm -rf*": "deny",
      "gopass*": "deny",
      "pass*": "deny",
    },
    "read": {
      "*": "ask"
    },
    "grep": {
      "*": "ask"
    },
    "glob": {
      "*": "ask"
    },
    "list": {
      "*": "ask"
    },
    // External directories
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow"
    },
    "doom_loop": "ask"
  },
  // MCP servers configuration
  "mcp": {
    "clickhouse-docs": {
      "type": "remote",
      "url": "https://clickhouse.mcp.kapa.ai/",
      "enabled": false,
      "headers": {}
    }
  },
  // Plugins
  "plugin": []
}
