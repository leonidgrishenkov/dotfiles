# vim: set filetype=fish:

# Catppuccin frappe theme (built into fish)
# Apply via 'set' so colors are under version control, not just in fish_variables
set -g fish_color_normal normal
set -g fish_color_command 8caaee
set -g fish_color_param eebebe
set -g fish_color_keyword f4b8e4
set -g fish_color_quote a6d189
set -g fish_color_redirection ef9f76
set -g fish_color_end 85c1dc
set -g fish_color_comment 838ba7
set -g fish_color_error e78284
set -g fish_color_gray 626880

set -g fish_color_autosuggestion 626880
set -g fish_color_cursor f4b8e4
set -g fish_color_selection --background=414559
set -g fish_color_search_match --background=414559
set -g fish_color_status e78284
set -g fish_color_cancel e78284

set -g fish_pager_color_progress 626880
set -g fish_pager_color_prefix 8caaee
set -g fish_pager_color_completion normal
set -g fish_pager_color_description 81c8be
set -g fish_pager_color_selected_background --background=414559
set -g fish_pager_color_background
