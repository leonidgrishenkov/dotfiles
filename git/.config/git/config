# vim: set filetype=gitconfig:
[user]
	name = Leonid Grishenkov
    email = grishenkovleonid@gmail.com
[init]
    defaultBranch = main
[core]
    editor = nvim
    pager = delta
[interactive]
    diffFilter = delta --color-only
[merge]
    conflictStyle = zdiff3
    tool = nvimdiff
[mergetool]
	prompt = false
	keepBackup = false
[diff]
    colorMoved = default
[diff]
	algorithm = histogram
	colorMoved = default
	tool = nvimdiff
    submodule = log
[difftool]
	prompt = false
[pull]
    rebase = true
[rebase]
	autoStash = true
	autoSquash = true
	updateRefs = true

[include]
    path = ~/.config/delta/config

[includeIf "hasconfig:remote.*.url:https://github.com/leonidgrishenkov/**"]
    path = ~/.config/git/include/github-personal

[includeIf "hasconfig:remote.*.url:ssh://git@bitbucket.playteam.ru/**"]
    path = ~/.config/git/include/okko-bitbucket
