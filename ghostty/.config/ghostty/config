# https://ghostty.org/docs/config

theme = light:Catppuccin Latte,dark:Catppuccin Macchiato

font-size = 14
font-family = JetBrainsMono Nerd Font Propo
font-family-bold = JetBrainsMono Nerd Font Propo Bold
font-family-italic = JetBrainsMono Nerd Font Propo Italic
font-family-bold-italic = JetBrainsMono Nerd Font Propo Bold Italic

cursor-text = 000000
cursor-style-blink = true

mouse-hide-while-typing = true
macos-auto-secure-input=true

window-decoration = true
window-padding-x = 4
window-padding-y = 2

background-opacity = 0.93
background-blur-radius = 95

keybind = super+alt+w=unbind
keybind = super+alt+right=unbind
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = super+alt+down=unbind
keybind = super+alt+shift+j=unbind
keybind = super+alt+left=unbind
keybind = super+alt+shift+w=unbind
keybind = super+alt+up=unbind
keybind = super+p=toggle_command_palette
keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right
keybind = alt+k=goto_split:up
keybind = alt+j=goto_split:down
keybind = alt+p=toggle_quick_terminal

# Pass Alt key combinations to applications like Zellij
macos-option-as-alt = true
macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden

# Disable title
title = ""

shell-integration=detect
# I turned 'title' feature off in favor of setting title via zsh hooks.
shell-integration-features=no-title

quick-terminal-screen=mouse
quick-terminal-position=center
quick-terminal-size=65%,65%
quick-terminal-animation-duration=0

notify-on-command-finish=unfocused
notify-on-command-finish-action=bell,notify
notify-on-command-finish-after=5s

progress-style=true

split-divider-color=#EBA0AC
