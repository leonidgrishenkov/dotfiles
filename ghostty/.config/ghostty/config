# https://ghostty.org/docs/config

theme = light:Catppuccin Latte,dark:Catppuccin Macchiato

font-size = 14
font-family = JetBrainsMono Nerd Font Propo
font-family-bold = JetBrainsMono Nerd Font Propo Bold
font-family-italic = JetBrainsMono Nerd Font Propo Italic
font-family-bold-italic = JetBrainsMono Nerd Font Propo Bold Italic

cursor-text = 000000
cursor-style-blink = true
cursor-click-to-move = true

mouse-hide-while-typing = true
macos-auto-secure-input=true

window-decoration = true
window-padding-x = 4
window-padding-y = 2

background-opacity = 0.75
background-blur-radius = 10
background-blur=macos-glass-regular

keybind = super+alt+w=unbind
keybind = super+alt+right=unbind
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = super+alt+down=unbind
keybind = super+alt+shift+j=unbind
keybind = super+alt+left=unbind
keybind = super+alt+shift+w=unbind
keybind = super+alt+up=unbind
keybind = super+p=toggle_command_palette
keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right
keybind = alt+k=goto_split:up
keybind = alt+j=goto_split:down
# Global key to toggle quick terminal inside Ghostty from everywhere.
# WARN: currently it works only on macOS.
keybind = global:super+g=toggle_quick_terminal

# Use left Option key as an Alt key on macOS.
macos-option-as-alt=left

# jump backwards/forwards through prompt boundaries in the scrollback
keybind = shift+up=jump_to_prompt:-1
keybind = shift+down=jump_to_prompt:1

# Pass Alt key combinations to applications like Zellij
macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden

# Disable title
title = ""

shell-integration=detect
# I turned 'title' feature off in favor of setting title via zsh hooks, because I configured its format differently.
shell-integration-features=no-title,ssh-env,ssh-terminfo

scrollback-limit = 100000

quick-terminal-screen=mouse
quick-terminal-position=center
quick-terminal-size=65%,65%
quick-terminal-animation-duration=0

notify-on-command-finish=unfocused
notify-on-command-finish-action=bell,notify
notify-on-command-finish-after=5s
bell-features=border,title,no-attention
macos-icon=holographic

progress-style=true

split-divider-color=#EBA0AC

# Additional commad palette items
command-palette-entry = title:"Quick terminal",description:"Toggle quick terminal",action:toggle_quick_terminal
